# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017
DATABASE_NAME=ai_prescription

# ─────────────────────────────────────────────
# JWT / Security
# ─────────────────────────────────────────────
SECRET_KEY=supersecretkey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=True

# ─────────────────────────────────────────────
# SMS Notifications (Twilio)
# ─────────────────────────────────────────────
# Sends "Welcome to AI Prescription System" via SMS
# to the user's phone number on every successful login.
#
# To enable:
#   1. Sign up free at https://www.twilio.com/try-twilio
#   2. Get a Twilio phone number from the console
#   3. Set NOTIFY_SMS_ENABLED=true and fill in your credentials below
# ─────────────────────────────────────────────
NOTIFY_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890