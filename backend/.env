# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017
DATABASE_NAME=ai_prescription

# ─────────────────────────────────────────────
# JWT / Security
# ─────────────────────────────────────────────
SECRET_KEY=supersecretkey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=True

# ─────────────────────────────────────────────
# Email Notifications (SMTP)
# ─────────────────────────────────────────────
# Set NOTIFY_EMAIL_ENABLED=true and fill the credentials below to
# send a welcome email on every successful login.
#
# Gmail users: generate an App Password at
#   https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled)
# ─────────────────────────────────────────────
NOTIFY_EMAIL_ENABLED=false
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=your_gmail@gmail.com
NOTIFY_SMTP_PASS=your_gmail_app_password
NOTIFY_FROM_NAME=AI Prescription System

# ─────────────────────────────────────────────
# SMS Notifications (Twilio)
# ─────────────────────────────────────────────
# Set NOTIFY_SMS_ENABLED=true and fill in your Twilio sandbox / production
# credentials to send an SMS on every successful login.
#
# Twilio console: https://console.twilio.com
# ─────────────────────────────────────────────
NOTIFY_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890